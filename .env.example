# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quantum?schema=public"

PORT=3000
JWT_SECRET=change-this-to-a-long-random-string
ALLOWED_ORIGINS=https://baitursagynbekov3-stack.github.io,https://kvantum-api.vercel.app
ADMIN_EMAILS=owner@example.com
SERVE_STATIC=true

# Real AI chatbot (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram lead notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email notifications (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@kvantum.us

# Stripe checkout
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SITE_URL=https://kvantum.us
# Fallback conversion rates to USD for currencies not directly supported by Stripe
STRIPE_USD_PER_KGS=0.0114
STRIPE_USD_PER_RUB=0.011
STRIPE_USD_PER_UZS=0.000079
STRIPE_USD_PER_KZT=0.002
STRIPE_USD_PER_EUR=1.09
STRIPE_USD_PER_GBP=1.27

# n8n workflow webhooks (all optional)
N8N_REGISTRATION_WEBHOOK_URL=
N8N_PURCHASE_WEBHOOK_URL=
N8N_CONSULTATION_WEBHOOK_URL=

# Optional webhook for direct Google Sheets lead logging (Apps Script/Make/n8n)
GOOGLE_SHEETS_WEBHOOK_URL=
# Optional shared secret sent as header: x-webhook-secret
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_WEBHOOK_TIMEOUT_MS=8000

# Public endpoint protection
BOOKING_RATE_LIMIT_WINDOW_MS=600000
BOOKING_RATE_LIMIT_MAX=8
NOTIFY_RATE_LIMIT_WINDOW_MS=300000
NOTIFY_RATE_LIMIT_MAX=20

# Optional captcha for /api/book-consultation (Cloudflare Turnstile)
BOOKING_CAPTCHA_REQUIRED=false
# You can set either TURNSTILE_SECRET_KEY or BOOKING_CAPTCHA_SECRET
TURNSTILE_SECRET_KEY=
BOOKING_CAPTCHA_SECRET=
BOOKING_CAPTCHA_VERIFY_TIMEOUT_MS=5000
TURNSTILE_SITE_KEY=

# Password reset security
# true = allow returning reset code in API response (dev-only convenience)
ALLOW_INSECURE_RESET_CODE_RESPONSE=false
